---
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteNav from '../components/SiteNav.astro'
import SiteFooter from '../components/SiteFooter.astro'
import SidebarLayout from '../components/ui/SidebarLayout.astro'
import FaqGroup from '../components/faq/FaqGroup.astro'
import { faqGroups } from '../data/faq.js'

const sidebarSections = [
  {
    heading: 'Categories',
    links: faqGroups.map((group) => ({ href: `#${group.id}`, label: group.title }))
  }
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqGroups.flatMap((group) =>
    group.items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer }
    }))
  )
}
const faqSchemaJson = JSON.stringify(faqSchema).replace(/</g, '\\u003c')
---

<BaseLayout
  title="SlayZone — FAQ"
  description="SlayZone FAQ: workflow, supported AI coding agents (Claude Code, Codex, Gemini), privacy, local-first data storage, pricing, platform requirements."
  canonicalPath="/faq"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={faqSchemaJson} />
  </Fragment>
  <Fragment slot="nav"><SiteNav current="faq" /></Fragment>
  <SidebarLayout
    title="Frequently Asked Questions"
    subtitle="Quick answers to common questions about SlayZone's workflow, agents, and privacy."
    sidebarSections={sidebarSections}
  >
    {faqGroups.map((group) => (
      <FaqGroup id={group.id} title={group.title} items={group.items} />
    ))}
  </SidebarLayout>
  <Fragment slot="footer"><SiteFooter /></Fragment>
</BaseLayout>

<script>
  const sections = document.querySelectorAll<HTMLElement>('.faq-group')
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.docs-sidebar a')
  function update() {
    let current = ''
    sections.forEach((section) => {
      if (window.scrollY >= section.offsetTop - 150) {
        current = section.id
      }
    })
    navLinks.forEach((a) => {
      a.classList.toggle('active', a.getAttribute('href') === '#' + current)
    })
  }
  window.addEventListener('scroll', update, { passive: true })
  update()
</script>
