{
  "name": "@slayzone/app",
  "version": "0.30.0",
  "private": true,
  "repository": "github:debuglebowski/SlayZone",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:protocol": "SLAYZONE_REGISTER_DEV_PROTOCOL=1 electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:mac": "pnpm --filter @slayzone/cli build && npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:win:x64": "npm run build && electron-builder --win --x64",
    "build:win:arm64": "npm run build && electron-builder --win --arm64",
    "build:win:all": "npm run build && electron-builder --win --x64 --arm64",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsgo --noEmit -p tsconfig.node.json && tsgo --noEmit -p tsconfig.web.json",
    "test:db:migrations": "ELECTRON_RUN_AS_NODE=1 npx electron --import tsx/esm src/main/db/ai-config-slug-migration.test.ts && ELECTRON_RUN_AS_NODE=1 npx electron --import tsx/esm src/main/db/agent-panel-rename-migration.test.ts",
    "test:e2e": "npx playwright test --config playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config playwright.config.ts --headed",
    "test:e2e:loop": "bash e2e-loop.sh",
    "test:e2e:loop:stop": "bash e2e-loop.sh --stop-on-fail",
    "test:e2e:parallel": "bash e2e-parallel.sh"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.90",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@slayzone/agent-turns": "workspace:*",
    "@slayzone/ai-config": "workspace:*",
    "@slayzone/automations": "workspace:*",
    "@slayzone/diagnostics": "workspace:*",
    "@slayzone/feedback": "workspace:*",
    "@slayzone/file-editor": "workspace:*",
    "@slayzone/history": "workspace:*",
    "@slayzone/hooks": "workspace:*",
    "@slayzone/icons": "workspace:*",
    "@slayzone/integrations": "workspace:*",
    "@slayzone/markdown": "workspace:*",
    "@slayzone/onboarding": "workspace:*",
    "@slayzone/platform": "workspace:*",
    "@slayzone/projects": "workspace:*",
    "@slayzone/settings": "workspace:*",
    "@slayzone/shortcuts": "workspace:*",
    "@slayzone/suspense": "workspace:*",
    "@slayzone/tags": "workspace:*",
    "@slayzone/task": "workspace:*",
    "@slayzone/task-artifacts": "workspace:*",
    "@slayzone/task-terminals": "workspace:*",
    "@slayzone/tasks": "workspace:*",
    "@slayzone/telemetry": "workspace:*",
    "@slayzone/terminal": "workspace:*",
    "@slayzone/test-panel": "workspace:*",
    "@slayzone/transport": "workspace:*",
    "@slayzone/types": "workspace:*",
    "@slayzone/ui": "workspace:*",
    "@slayzone/usage-analytics": "workspace:*",
    "@slayzone/worktrees": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "electron-updater": "^6.7.3",
    "express": "^5.2.1",
    "framer-motion": "^12.15.0",
    "fzf": "^0.5.2",
    "lucide-react": "^0.562.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hotkeys-hook": "^5.2.3",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.0.3",
    "electron-builder": "~25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "posix": "^4.2.0"
  }
}
