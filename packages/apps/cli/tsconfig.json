{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "paths": {
      "*": ["./*"],
      "@slayzone/projects/shared": ["../../domains/projects/src/shared/index.ts"],
      "@slayzone/terminal/shared": ["../../domains/terminal/src/shared/index.ts"],
      "@slayzone/task/shared/types": ["../../domains/task/src/shared/types.ts"],
      "@slayzone/task/shared/panel-config": ["../../domains/task/src/shared/panel-config.ts"],
      "@slayzone/task/shared/handoff": ["../../domains/task/src/shared/handoff.ts"],
      "@slayzone/task/shared/reparent-validation": [
        "../../domains/task/src/shared/reparent-validation.ts"
      ],
      "@slayzone/ai-config/shared": ["../../domains/ai-config/src/shared/index.ts"],
      "@slayzone/automations/shared": ["../../domains/automations/src/shared/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src"]
}
